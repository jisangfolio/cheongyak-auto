#!/bin/bash
# 청약 알리미 대시보드 실행 런처 (macOS)
# 사용법: 이 파일을 바탕화면에 복사 → 아래 두 경로를 본인 환경에 맞게 수정
#         → 터미널에서  chmod +x "청약 알리미.command"  → 더블클릭
cd "/path/to/cheongyak-auto" || { echo "프로젝트 폴더를 찾을 수 없습니다"; read -n1 -r; exit 1; }
pkill -f "streamlit run dashboard/app.py" 2>/dev/null
sleep 1
echo "🏠 청약 알리미 대시보드를 여는 중... 브라우저가 자동으로 열립니다."
exec /path/to/streamlit run dashboard/app.py
